# Backend
DATABASE_URL=sqlite:///./data/app.db
FIRECRAWL_API_KEY=
FIRECRAWL_BASE=https://api.firecrawl.dev/v2
FIRECRAWL_ALLOWED_DOMAINS=theverge.com,wired.com,techcrunch.com,arstechnica.com,technologyreview.com,reuters.com,apnews.com,bbc.com,theguardian.com,nytimes.com
DDG_BASE=https://html.duckduckgo.com/html/
DDG_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
DDG_ACCEPT_LANGUAGE=es-ES,es;q=0.9,en;q=0.8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FRONTEND_ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@zia.ai

# Scheduler
ENABLE_SCHEDULER=true
DAILY_DIGEST_HOUR=8
TZ=America/Bogota
