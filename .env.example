# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
DATABASE_URL=sqlite:///./data/app.db
NEWS_API_KEY=
NEWS_API_BASE=https://newsapi.org/v2
NEWS_ALLOWED_SOURCES=the-verge,wired,techcrunch,ars-technica,mit-technology-review,reuters,associated-press,bbc-news,the-guardian-uk,the-new-york-times
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FRONTEND_ORIGIN=http://localhost:3000

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@zia.ai

# Scheduler
ENABLE_SCHEDULER=true
DAILY_DIGEST_HOUR=8
TZ=America/Bogota
