# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Backend
DATABASE_URL=sqlite:///./data/app.db
FIRECRAWL_API_KEY=
FIRECRAWL_BASE=https://api.firecrawl.dev/v2
FIRECRAWL_ALLOWED_DOMAINS=theverge.com,wired.com,techcrunch.com,arstechnica.com,technologyreview.com,reuters.com,apnews.com,bbc.com,theguardian.com,nytimes.com,nature.com,science.org,arxiv.org,openai.com,deepmind.com,anthropic.com,huggingface.co,stanford.edu
DDG_BASE=https://html.duckduckgo.com/html/
DDG_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/122.0.0.0 Safari/537.36
DDG_ACCEPT_LANGUAGE=es-ES,es;q=0.9,en;q=0.8
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
FRONTEND_ORIGIN=http://localhost:3000
PUBLIC_BASE_URL=http://localhost:8000
REDIS_URL=redis://redis:6379/0
NEWS_CACHE_TTL_MINUTES=15
RATE_LIMIT_SUMMARY_PER_HOUR=30
RATE_LIMIT_SEND_PER_HOUR=10
RATE_LIMIT_SUBSCRIBE_PER_HOUR=5
NEWS_PAGE_SIZE_DEFAULT=8
NEWS_PAGE_SIZE_MAX=20
NEWS_MAX_LIMIT=60
ARTICLE_TTL_HOURS=24
NEWS_PREFETCH_ENABLED=true
NEWS_PREFETCH_INTERVAL_MINUTES=60
NEWS_PREFETCH_PAGE_SIZE=25
VALIDATION_ENABLED=true
VALIDATION_MAX=20
VALIDATION_USE_LLM=false
CONTEXT_MAX_CHARS=700

# Email (SMTP)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=no-reply@zia.ai

# Scheduler
ENABLE_SCHEDULER=true
DAILY_DIGEST_HOUR=8
TZ=America/Bogota
